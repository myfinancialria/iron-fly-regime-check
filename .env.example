# --- Upstox API (live index + option quotes) ---
# Create a personal app at https://account.upstox.com/developer/apps
# The redirect URI must match exactly what you registered on the app.
UPSTOX_API_KEY=your_api_key_here
UPSTOX_API_SECRET=your_api_secret_here
UPSTOX_REDIRECT_URI=https://127.0.0.1:5000/callback
# Filled in automatically by `python -m ironfly_check login <redirect-url>`.
# Upstox access tokens expire daily ~03:30 IST — re-run login each morning.
UPSTOX_TOKEN=

# --- GIFT NIFTY pre-market indication (Stage-1 expected-gap filter) ---
# Upstox does NOT carry GIFT NIFTY. Paste the current level here each morning to
# override the (fragile) scraper. Leave blank to let the scraper try, or if you
# want to score the day on the actual 09:20 gap alone.
IFC_GIFT_NIFTY=

# --- Optional overrides ---
# IFC_CAPITAL=2000000        # ₹ capital used for position sizing
